ANTHROPIC_API_KEY=""

# https://docs.claude.com/en/docs/about-claude/models/overview
# ANTHROPIC_MODEL=""

SITE_HOSTNAME=""

# Story generation form defaults (uses values from config.ts if not defined)
# NEXT_PUBLIC_DEFAULT_TARGET_LANGUAGE="nl-NL"
# NEXT_PUBLIC_DEFAULT_STORY_LENGTH=300
# NEXT_PUBLIC_DEFAULT_STORY_LENGTH_MIN=50
# NEXT_PUBLIC_DEFAULT_STORY_LENGTH_MAX=1000
# NEXT_PUBLIC_DEFAULT_DIFFICULTY_LEVEL="B1"
# NEXT_PUBLIC_DEFAULT_INCLUDE_VOCABULARY="false"
# NEXT_PUBLIC_DEFAULT_INCLUDE_GRAMMAR="false"

# Randomises via getRandomTopic() if not defined
# NEXT_PUBLIC_DEFAULT_TOPIC=""

# Lock checkboxes to add vocabulary and grammar notes
NEXT_PUBLIC_DISABLE_VOCABULARY_CHECKBOX="false"
NEXT_PUBLIC_DISABLE_GRAMMAR_CHECKBOX="false"

# NEXT_PUBLIC_ANTHROPIC_USAGE_URL=""

# Set for GitHub Action deploy
# AWS_SECRET_ACCESS_KEY=""
# AWS_ACCESS_KEY_ID=""
# AWS_REGION="us-east1"

# DEBUG="true"

# https://console.cloud.google.com/apis/credentials
GOOGLE_AUTH_CLIENT_ID=""
GOOGLE_AUTH_CLIENT_SECRET=""

# https://better-auth.com/docs/reference/options
# npx auth secret
BETTER_AUTH_SECRET=""
# BETTER_AUTH_URL=""

# https://console.cloud.google.com/welcome
# Google Cloud Text-to-Speech (optional, for TTS functionality)
# Option 1: Set GOOGLE_APPLICATION_CREDENTIALS to path of service account JSON key file
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account-key.json"
# Option 2: For local development, use: gcloud auth application-default login
# GOOGLE_CLOUD_PROJECT="your-project-id"
# GOOGLE_CLOUD_PRIVATE_KEY=""
