{
  "name": "bite-sized-stories",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "build": "next build",
    "dev": "sst dev",
    "dev-cmd": "next dev",
    "dev:db": "turso dev -f db/local.db",
    "lint": "eslint",
    "check": "tsc --noEmit",
    "start": "next start",
    "deploy": "dotenv -e .env.production -- sst deploy --stage production",
    "deploy:staging": "dotenv -e .env.staging -- sst deploy --stage staging",
    "db:init": "rm -rf db/local.* db/migrations/* && drizzle-kit generate && drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:prod": "dotenv -e .env.production -- drizzle-kit migrate",
    "db:migrate:staging": "dotenv -e .env.staging -- drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:studio:prod": "dotenv -e .env.production -- drizzle-kit studio",
    "db:studio:staging": "dotenv -e .env.staging -- drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:push:prod": "dotenv -e .env.production -- drizzle-kit push",
    "db:push:staging": "dotenv -e .env.staging -- drizzle-kit push",
    "db:seed": "tsx scripts/seed-settings.ts",
    "db:seed:prod": "dotenv -e .env.production -- tsx scripts/seed-settings.ts",
    "db:seed:staging": "dotenv -e .env.staging -- tsx scripts/seed-settings.ts",
    "generate:audio": "tsx scripts/generateAudio.ts --",
    "generate:audio:prod": "dotenv -e .env.production -- tsx scripts/generateAudio.ts --",
    "generate:audio:staging": "dotenv -e .env.staging -- tsx scripts/generateAudio.ts --"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.50",
    "@ai-sdk/react": "^3.0.107",
    "@google-cloud/text-to-speech": "^6.4.0",
    "@libsql/client": "^0.17.0",
    "@libsql/linux-x64-gnu": "^0.5.22",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "ai": "^6.0.105",
    "better-auth": "^1.5.1",
    "boolean": "^3.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "jotai": "^2.18.0",
    "lucide-react": "^0.575.0",
    "minimist": "^1.2.8",
    "next": "16.1.6",
    "nuqs": "^2.8.9",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "pluralize": "^8.0.0",
    "pretty-bytes": "^7.1.0",
    "pretty-ms": "^9.3.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hotkeys-hook": "^5.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "2.15.4",
    "tailwind-merge": "^3.5.0",
    "use-elapsed-time": "^3.0.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/minimist": "^1.2.5",
    "@types/node": "^24.11.0",
    "@types/pluralize": "^0.0.33",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "sst": "^4.1.3",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
